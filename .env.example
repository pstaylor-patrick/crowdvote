# region Local Development (Docker)
POSTGRES_URL=postgresql://crowdvote:crowdvote@localhost:5433/crowdvote
REDIS_URL=redis://localhost:6380
# endregion

# region Local
APP_URL=http://localhost:3000
# endregion

# region ngrok
# APP_URL=https://<your-subdomain>.ngrok-free.app
# endregion

ADMIN_PASSWORD=           # Leave empty to disable auth in dev
