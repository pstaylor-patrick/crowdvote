{
  "name": "crowdvote",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "db:generate": "pnpm --filter @crowdvote/web db:generate",
    "db:migrate": "pnpm --filter @crowdvote/web db:migrate",
    "db:push": "pnpm --filter @crowdvote/web db:push",
    "db:studio": "pnpm --filter @crowdvote/web db:studio",
    "db:nuke": "pnpm --filter @crowdvote/web db:nuke",
    "db:seed": "pnpm --filter @crowdvote/web db:seed",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "postinstall": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "turbo": "^2.4.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}
